{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "chain-evaluator output",
  "type": "object",
  "required": ["voice_score", "positioning_score", "findings", "confidence", "verdict"],
  "properties": {
    "voice_score": {"type": "integer", "minimum": 1, "maximum": 5},
    "positioning_score": {"type": "integer", "minimum": 1, "maximum": 5},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "quote", "why"],
        "properties": {
          "id": {"type": "string", "description": "stable finding id (F1, F2, ...) the writer references"},
          "severity": {
            "type": "string",
            "enum": ["must-fix", "improvement", "protect", "consideration"],
            "description": "must-fix: required correction, incl. any factual/mechanical misstatement the sources contradict. improvement: meaningful, optional, worth acting on. protect: exceptionally strong language the writer may NOT alter (its quote is mechanically verified to survive). consideration: minor, writer's call."
          },
          "quote": {"type": "string", "description": "the exact passage the finding is about"},
          "why": {"type": "string"}
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": ["why_chosen", "what_communicates", "standing", "risk"],
      "properties": {
        "why_chosen": {"type": "string"},
        "what_communicates": {"type": "string"},
        "standing": {"type": "string"},
        "risk": {"type": "string"}
      }
    },
    "comparison_note": {"type": "string"},
    "self_pushback": {"type": "string"},
    "verdict": {
      "type": "string",
      "enum": [
        "Strong candidate to publish",
        "Good candidate with one issue to review",
        "Interesting but somewhat exposed",
        "Strategically useful, but currently too generic",
        "Do not publish this version"
      ]
    }
  }
}
